rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return true; // Simplified for this app until real auth is requested
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidRoom(data) {
      return data.keys().hasAll(['code', 'theme', 'status', 'createdAt', 'hostId'])
        && data.code is string
        && data.theme is string
        && data.status in ['lobby', 'playing', 'ended']
        && data.hostId is string;
    }

    match /rooms/{roomId} {
      allow get: if true;
      allow create: if isValidId(roomId) && isValidRoom(request.resource.data);
      allow update: if (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'timer', 'currentRound', 'currentChoices', 'isProcessing', 'selectedChoiceId'])
      );

      match /players/{playerId} {
        allow read: if true;
        allow write: if isValidId(playerId);
      }

      match /narrations/{narrationId} {
        allow read: if true;
        allow create: if true;
      }
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
